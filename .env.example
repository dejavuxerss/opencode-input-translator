# Required: API key for the OpenAI-compatible translation service
# Get one from https://opencode.ai/auth (Zen API) or any OpenAI-compatible provider
TRANSLATOR_API_KEY=

# Required: Base URL of the translation API (e.g. https://api.openai.com)
# For OpenCode Zen: https://opencode.ai/zen/v1
TRANSLATOR_BASE_URL=

# Optional: Model to use for translation (default: gpt-5-nano-2025-08-07)
# For Zen MiniMax M2.5 Free: minimax-m2.5-free
TRANSLATOR_MODEL=gpt-5-nano-2025-08-07
